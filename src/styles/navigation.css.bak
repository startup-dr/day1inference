/* Override Distill fonts */
d-title h1,
d-article h1,
d-article h2,
d-article h3,
d-article h4,
d-article h5,
d-article h6 {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Fira Sans", "Droid Sans", "Helvetica Neue", Arial, sans-serif !important;
}

/* Site Navigation */
.site-nav {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: #232F3E;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: white;
    font-weight: 600;
    font-size: 1.1rem;
}

.nav-logo img {
    height: 32px;
    width: auto;
}

.nav-links {
    display: flex;
    gap: 2rem;
}

.nav-links a {
    text-decoration: none;
    color: white;
    font-weight: 500;
    transition: color 0.2s;
}

.nav-links a:hover {
    color: #d0ea65;
}

/* Article Cards (for timeline) */
.article-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid #eee;
}

.article-card:last-child {
    border-bottom: none;
}

.article-image {
    width: 200px;
    height: 120px;
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
}

.article-content {
    flex: 1;
}

.article-meta {
    font-size: 0.85rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
}

.article-card h3 {
    margin: 0.5rem 0;
    font-size: 1.5rem;
}

.article-card h3 a {
    color: inherit;
    text-decoration: none;
}

.article-card h3 a:hover {
    color: #007f80;
}

.article-card p {
    color: #666;
    margin: 0.5rem 0 0 0;
    line-height: 1.6;
}
