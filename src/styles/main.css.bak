/* ============================================
   Day 1 Inference - Article Pages
   ============================================ */

/* Reset & Base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    line-height: 1.6;
    color: #333;
    overflow-x: hidden;
}

/* ============================================
   Navigation Bar
   ============================================ */

nav {
    background: #1e2933;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
}

nav .logo {
    color: white;
    font-size: 1.25rem;
    font-weight: 600;
    text-decoration: none;
}

nav .links {
    display: flex;
    gap: 2rem;
}

nav .links a {
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    font-size: 0.95rem;
}

nav .links a:hover {
    color: white;
}

/* ============================================
   Article Typography & Content
   ============================================ */

article h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #1e2933;
}

article h2 {
    font-size: 1.8rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #1e2933;
}

article h3 {
    font-size: 1.4rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #1e2933;
}

article p {
    margin-bottom: 1rem;
}

article ul, article ol {
    margin-left: 2rem;
    margin-bottom: 1rem;
}

article li {
    margin-bottom: 0.5rem;
}

article code {
    background: #f5f5f5;
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: 'Monaco', 'Menlo', 'Consolas', monospace;
}

article pre {
    background: #f5f5f5;
    padding: 1rem;
    border-radius: 5px;
    overflow-x: auto;
    margin-bottom: 1rem;
}

article pre code {
    background: none;
    padding: 0;
}

article blockquote {
    border-left: 4px solid #0066cc;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #666;
    font-style: italic;
}

article a {
    color: #0066cc;
    text-decoration: none;
}

article a:hover {
    text-decoration: underline;
}

article img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
}

article table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
}

article th,
article td {
    padding: 0.75rem;
    text-align: left;
    border-bottom: 1px solid #e0e0e0;
}

article th {
    background: #f5f5f5;
    font-weight: 600;
}

/* ============================================
   Grid Layout System
   ============================================ */

body {
    display: grid;
    grid-template-columns:
        [screen-start] minmax(20px, 1fr)
        [page-start] 0px
        [toc-start] 150px [toc-end text-start] 800px [text-end]
        0px [page-end]
        minmax(20px, 1fr) [screen-end];
    grid-column-gap: 32px;
}

/* Wider centered layout for tools pages - NO TOC, PERFECTLY BALANCED */
body.tools-layout {
    grid-template-columns:
        [screen-start] minmax(20px, 1fr)
        [page-start toc-start toc-end text-start] 1600px [text-end page-end]
        minmax(20px, 1fr) [screen-end];
}

body > * {
    grid-column: screen;
}

.article-grid {
    display: contents;
}

/* ============================================
   Article Header
   ============================================ */

.article-header {
    grid-column: text;
    margin: 3rem 0 2rem 0;
}

.article-category {
    color: #999;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
}

.article-header h1 {
    font-size: 3rem;
    margin-bottom: 0.25rem;
    line-height: 1.2;
}

.article-header .subtitle {
    font-size: 1.4rem;
    color: #666;
}

/* ============================================
   Banner
   ============================================ */

.banner {
    grid-column: text;
    margin: 0 0 2rem 0;
}

.banner img {
    width: 100%;
    border-radius: 8px;
}

/* ============================================
   Metadata Section
   ============================================ */

.metadata {
    grid-column: screen;
    display: grid;
    grid-template-columns:
        [screen-start] minmax(20px, 1fr)
        [page-start] 0px
        [toc-start] 150px [toc-end text-start] 800px [text-end]
        0px [page-end]
        minmax(20px, 1fr) [screen-end];
    grid-column-gap: 32px;
    padding: 1.5rem 0;
    border-top: 1px solid #e0e0e0;
    border-bottom: 1px solid #e0e0e0;
    color: #666;
    font-size: 0.9rem;
}

body.tools-layout .metadata {
    grid-template-columns:
        [screen-start] minmax(20px, 1fr)
        [page-start toc-start toc-end text-start] 1600px [text-end page-end]
        minmax(20px, 1fr) [screen-end];
}

.metadata-wrapper {
    grid-column: text;
    display: flex;
    gap: 3rem;
}

.meta-item {
    text-align: left;
}

.meta-item strong {
    display: block;
    color: #999;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
    font-weight: 400;
}

.meta-item div {
    color: #444;
}

/* ============================================
   Table of Contents
   ============================================ */

.toc {
    grid-column: screen-start / toc-end;
    padding: 3rem 3rem 100vh 0;
    position: sticky;
    top: 80px;
    align-self: start;
    justify-self: end;
    border-right: 1px solid #e0e0e0;
}

.toc-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #999;
    margin-bottom: 0.75rem;
    font-weight: 600;
}

.toc-link {
    display: block;
    color: #666;
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 0.5rem;
}

.toc-link:hover {
    color: #0066cc;
}

.toc-3 {
    padding-left: 1rem;
    font-size: 0.8rem;
}

/* ============================================
   Article Body
   ============================================ */

.article-body {
    grid-column: text;
    margin-top: 0.5rem;
    font-size: 1.1rem;
    line-height: 1.7;
    color: #444;
    min-height: 100vh;
}

/* ============================================
   Responsive Design
   ============================================ */

@media (max-width: 1800px) {
    body.tools-layout {
        grid-template-columns:
            [screen-start] minmax(20px, 1fr)
            [page-start toc-start toc-end text-start] 1200px [text-end page-end]
            minmax(20px, 1fr) [screen-end];
    }
    
    body.tools-layout .metadata {
        grid-template-columns:
            [screen-start] minmax(20px, 1fr)
            [page-start toc-start toc-end text-start] 1200px [text-end page-end]
            minmax(20px, 1fr) [screen-end];
    }
}

@media (max-width: 1024px) {
    body,
    body.tools-layout {
        grid-template-columns:
            [screen-start page-start toc-start toc-end text-start]
            minmax(20px, 900px)
            [text-end page-end screen-end];
        padding: 0 2rem;
    }

    .toc {
        display: none;
    }

    .metadata {
        grid-template-columns: 1fr;
        padding: 1.5rem 2rem;
    }

    .metadata-wrapper {
        flex-direction: column;
        gap: 1rem;
    }
}
